# Copy to .env to configure. All values are optional — with no keys set, the
# system runs in deterministic STUB mode (no network), which is what the test
# suite uses.

# Provider selection: auto | stub | litellm
#   auto   -> litellm if an API key is present, else stub
#   stub   -> deterministic offline generation (no LLM calls)
#   litellm-> real multi-provider LLM calls (requires a key below)
LLM_PROVIDER=auto

# Default model (LiteLLM model id). Design default: latest Claude.
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# Provider keys (only one is needed for real calls).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Where blueprints/exports are persisted.
DATA_DIR=data
